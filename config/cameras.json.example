{
  "devices": {
    "492D95DE584B4559": {
      "notes": "",
      "packager_path": "68d49398005cf203e400043f",
      "type": "unifi",
      "name": "UNIFI_Camera_1",
      "camera_id": "T8400P0D148A87C0",
      "serial": "492D95DE584B4559",
      "host": "192.168.1.100",
      "mac": "AA:BB:CC:DD:EE:00",
      "rtsp_alias": "this value is exported into the environment by get_cameras_credentials function in .bash_utils, called by start.sh",
      "capabilities": [
        "ONVIF",
        "streaming"
      ],
      "stream_type": "WEBRTC",
      "_max_connections_note": "Max concurrent RTSP/HTTP connections camera can handle. 1=snap-polling only, no MediaMTX. Used to prevent overwhelming budget cameras.",
      "max_connections": 3,
      "onvif_port": 8000,
      "true_mjpeg": "false",
      "power_supply": "poe",
      "player_settings": {
        "hls_js": {
          "enableWorker": true,
          "lowLatencyMode": true,
          "liveSyncDurationCount": 0.5,
          "liveMaxLatencyDurationCount": 3,
          "maxLiveSyncPlaybackRate": 1.5,
          "backBufferLength": 3
        }
      },
      "mjpeg_snap": {
        "sub": {
          "enabled": true,
          "width": 640,
          "height": 480,
          "fps": 5,
          "timeout_ms": 5000
        },
        "main": {
          "enabled": true,
          "width": 1280,
          "height": 720,
          "fps": 5,
          "timeout_ms": 8000
        }
      },
      "neolink": {
        "port": 8554,
        "buffer_size": 20,
        "stream": "mainStream"
      },
      "ll_hls": {
        "publisher": {
          "protocol": "rtsp",
          "host": "nvr-packager",
          "port": 8554,
          "path": "492D95DE584B4559",
          "rtsp_transport": "tcp"
        },
        "audio": {
          "enabled": true,
          "c:a": "libopus",
          "b:a": "32k",
          "_note": "UniFi outputs AAC LC @ 16kHz mono - transcode to Opus for WebRTC compatibility"
        },
        "video_sub": {
          "c:v": "libx264",
          "preset": "veryfast",
          "tune": "zerolatency",
          "profile:v": "baseline",
          "pix_fmt": "yuv420p",
          "r": 15,
          "g": 15,
          "keyint_min": 15,
          "b:v": "800k",
          "maxrate": "800k",
          "bufsize": "1600k",
          "x264-params": "scenecut=0:min-keyint=15:open_gop=0",
          "force_key_frames": "expr:gte(t,n_forced*1)",
          "vf": "scale=320:240"
        },
        "video_main": {
          "c:v": "copy",
          "preset": "veryfast",
          "tune": "zerolatency",
          "profile:v": "baseline",
          "pix_fmt": "yuv420p",
          "r": 15,
          "g": 15,
          "keyint_min": 15,
          "b:v": "2000k",
          "maxrate": "2000k",
          "bufsize": "4000k",
          "x264-params": "scenecut=0:min-keyint=15:open_gop=0",
          "force_key_frames": "expr:gte(t,n_forced*1)",
          "vf": "scale=1280:720"
        }
      },
      "rtsp_input": {
        "rtsp_transport": "tcp",
        "timeout": 5000000,
        "analyzeduration": 1000000,
        "probesize": 1000000,
        "use_wallclock_as_timestamps": 1,
        "fflags": "nobuffer"
      },
      "rtsp_output": {
        "map": [
          "0:v:0"
        ],
        "c:v": "libx264",
        "profile:v": "baseline",
        "pix_fmt": "yuv420p",
        "r": 15,
        "vf": "scale=320:240",
        "tune": "zerolatency",
        "g": 7,
        "keyint_min": 7,
        "preset": "ultrafast",
        "f": "HLS",
        "hls_time": "0.5",
        "hls_list_size": "1",
        "hls_flags": "independent_segments+program_date_time+append_list+delete_segments+split_by_time",
        "hls_fmp4_init_resend": 1,
        "muxpreload": 0,
        "muxdelay": 0,
        "hls_segment_type": "fmp4",
        "hls_fmp4_init_filename": "init.mp4",
        "movflags": "+frag_keyframe+empty_moov+default_base_moof",
        "hls_delete_threshold": "1"
      },
      "hidden": false,
      "ui_health_monitor": true,
      "reversed_pan": false,
      "reversed_tilt": false,
      "id": "0e0a40be0686412c",
      "two_way_audio": {
        "enabled": false,
        "protocol": null,
