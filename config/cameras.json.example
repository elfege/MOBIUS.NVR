        },
        "audio_output": {
          "codec": "pcmu",
          "container": null,
          "bitrate": null,
          "sample_rate": 8000,
          "channels": 1
        },
        "eufy_p2p": {
          "requires_p2p_livestream": false
        },
        "onvif": {
          "codec": "pcmu",
          "sample_rate": 8000,
          "backchannel_url": null,
          "go2rtc_stream": null
        },
        "baichuan": {
          "enabled": false
        }
      },
      "station": "T8010PE42632407A",
