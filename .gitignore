# =============================================================================
# NVR Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Config files — contain credentials and real device data. NEVER track.
# Only the template (no secrets) and the loader script are tracked.
# -----------------------------------------------------------------------------
config/
!config/go2rtc.yaml.template
!config/recording_config_loader.py

# -----------------------------------------------------------------------------
# Documentation - track only specific files
# -----------------------------------------------------------------------------
docs/
DOCS/

# -----------------------------------------------------------------------------
# Project-specific ignores
# -----------------------------------------------------------------------------
**/0_*
persistent.json
persistent.json.backup_2
bootstrap.json
tree.md
neolink/target/

# Personal scripts (untracked — use _deploy.sh and _start.sh instead)
deploy.sh
start.sh

# Deprecated/unused scripts
eufy_bridge.sh
eufy_bridge.py
eufy_bridge_client_verbose.py
eufy_bridge_watchdog.py
ptz_pan_right.py
ptz_server.py
PTZ_Discovery.py
stop_nvr_standalone.sh
**/DAMS_flat_copy.sh

# Claude/chat files
claude_rules.md
CLAUDE.md
*claude*
chat.md
chat*.md

