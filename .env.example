# =============================================================================
# MOBIUS.NVR — example environment file
# =============================================================================
# Copy this to `.env` and edit the values that aren't right for your host.
# Most defaults work out of the box for a single-machine deployment using
# relative paths under the repo. For a real production layout (separate
# drives for recent vs archive recordings, etc.), edit the storage paths.
#
# Lines below cover EVERY ${VAR} the docker-compose.yml references. If you
# add a new env var to docker-compose.yml, you MUST add the matching line
# here AND mirror it in .env.test — the conformity test in
# tests/test_env_conformity.py refuses to pass otherwise.
# =============================================================================

# --- Credential source ------------------------------------------------------
# true  → secrets in secrets.env (no AWS dependency, easiest for new users)
# false → pull from AWS Secrets Manager (recommended for production)
ENV_BASED_CONFIG=true

# --- Storage paths ----------------------------------------------------------
# Where recordings live on the host. The defaults are relative to the repo
# so a fresh clone works without sudo. For real deployments, point these at
# actual disk mounts (e.g. /mnt/recordings/recent).
NVR_RECORDING_PATH=./data/recordings/recent
NVR_STORAGE_PATH=./data/recordings/archive
NVR_ALTERNATE_RECORDING_STORAGE=./data/recordings/alternate
NVR_POSTGRES_DATA=./data/postgres
# Evidence collection volume. Optional — only used when the evidence
# collection feature is ON (default off).
NVR_LITIGATION_PATH=./data/evidence
NVR_SSH_CONFIG_ENTRIES_PATH=./data/ssh_config_entries

# --- Network ----------------------------------------------------------------
NVR_NETWORK_NAME=0_mobiusnvr_nvr-net
NVR_ANAMNESIS_NETWORK=0_anamnesis_anamnesis-net
NVR_EDGE_HTTP_PORT=8081
NVR_EDGE_HTTPS_PORT=8444
NVR_ADMIN_PORT=9100
# Local host IP — used as a SAN in the TLS cert. Leave empty to auto-detect.
NVR_LOCAL_HOST_IP=
NVR_HOST_IP=

# --- Flask --------------------------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=0
NVR_LOG_LEVEL=INFO
NVR_API_TOKEN=

# --- UniFi Protect (optional) -----------------------------------------------
# Set to 1 if you have a UniFi Protect controller and want to use it.
# Otherwise leave at 0 — UniFi cameras can still stream directly via RTSP.
NVR_USE_PROTECT=0
NVR_PROTECT_HOST=
NVR_PROTECT_PORT=7447

# --- Eufy bridge (optional) -------------------------------------------------
# Set to 1 if you have Eufy cameras. The bridge handles Eufy's P2P protocol.
NVR_USE_EUFY_BRIDGE=0
NVR_USE_EUFY_BRIDGE_WATCHDOG=0

# --- Hubitat (optional, for outlet power-cycle) -----------------------------
# Hubitat smart-home hub for cycling power on misbehaving cameras.
NVR_HUBITAT_HUB_IP=

# --- Stream watchdog --------------------------------------------------------
NVR_STREAM_WATCHDOG_ENABLED=1
NVR_STREAM_WATCHDOG_INTERVAL_SEC=300
NVR_STREAM_WATCHDOG_RESTART_LIMIT=3

# --- HLS tuning -------------------------------------------------------------
NVR_HLS_SEGMENT_TIME=4
NVR_HLS_MAX_SEGMENTS=6
