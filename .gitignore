# =============================================================================
# NVR Project .gitignore
# =============================================================================
.gitignore 

# -----------------------------------------------------------------------------
# Config files (contain credentials) - track only .example and code files
# -----------------------------------------------------------------------------
config/


# -----------------------------------------------------------------------------
# Documentation - track only specific files
# -----------------------------------------------------------------------------
docs/
DOCS/

# -----------------------------------------------------------------------------
# Project-specific ignores
# -----------------------------------------------------------------------------
**/0_*
# Evidence collection volume — symlink at ~/0_MOBIUS.NVR/litigation
# points to /litigation (a separate disk on dellserver). Never commit
# this symlink, its target, or any of its contents.
/litigation
litigation/
persistent.json
persistent.json.backup_2
bootstrap.json
tree.md
neolink/target/

# Version tracker — operator-editable source of truth for main's
# semver. The post-merge/post-commit hooks auto-bump this file and
# mirror it as `v<version>` git tags. Local-only, never tracked.
.tag

# Personal scripts (untracked — use _deploy.sh and _start.sh instead)
deploy.sh
start.sh

# Backup files left by canonical-rule propagation agents
*.bak
*.bak.before_*

# SSH keys for container-to-host restart (private keys, never commit)
.ssh/

# Restart log (written by start.sh when triggered from app)
restart_from_app.log

# Deprecated/unused scripts
eufy_bridge.sh
eufy_bridge.py
eufy_bridge_client_verbose.py
eufy_bridge_watchdog.py
ptz_pan_right.py
ptz_server.py
PTZ_Discovery.py
stop_nvr_standalone.sh
**/DAMS_flat_copy.sh

# Claude/chat files
claude_rules.md
CLAUDE.md
*claude*
chat.md
chat*.md

# -----------------------------------------------------------------------------
# Security - certificates and environment
# -----------------------------------------------------------------------------
*.pem
*.cert
*.rsa
.env
.env.*
secrets.env

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
venv/
env/
ENV/
*.egg-info/
*.egg

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-debug.log

# -----------------------------------------------------------------------------
# Build/Distribution
# -----------------------------------------------------------------------------
dist/
build/
develop-eggs/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# -----------------------------------------------------------------------------
# Archives and compressed files
# -----------------------------------------------------------------------------
*.tar.gz
*.tar.bz2
*.tar
*.zip
*.tgz
*.gz
*.bz2
*.tbz
*.dmg
*.xpi
*.gem
*.rar
*.7z

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# Loose `test_*` etc. anywhere in the tree stays ignored (preserves the
# legacy convention of ad-hoc scratch tests not being tracked). The
# proper test suite lives under tests/ and IS tracked — exception below.
test_*
_test*
*_test*
TESTS/
TESTS
htmlcov/
# Tracked test suite (CI-runnable). Adding new tests goes here.
# Narrow exceptions only — pycache + coverage artifacts stay ignored.
!/tests/
!/tests/**/test_*.py
!/tests/**/conftest.py
!/tests/**/README*.md
/tests/**/__pycache__/
/tests/.pytest_cache/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# -----------------------------------------------------------------------------
# Logs and temp files
# -----------------------------------------------------------------------------
*.log
**/app.log.*
*temp*
!templates/

# -----------------------------------------------------------------------------
# Backups, archives, copies, drafts
# -----------------------------------------------------------------------------
*backup*
**/backup/
**/backups/
**/archive/
!docs/archive/
!docs/archive/handoffs/
!docs/archive/handoffs/**
*archive*
ARCHIVE/
*~.bak
*.backup
*.bak~
*.bak
*copy*
!**/copy_installation_files.sh
*draft*

# -----------------------------------------------------------------------------
# Media files
# -----------------------------------------------------------------------------
*.jpg

# -----------------------------------------------------------------------------
# Text files (track only requirements.txt)
# -----------------------------------------------------------------------------
*.txt
!requirements.txt

# -----------------------------------------------------------------------------
# HLS streaming segments
# -----------------------------------------------------------------------------
**/streams/
*stream/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
.git

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# VPN related
# -----------------------------------------------------------------------------
*vpn*


**/retrieved_files_post_catastrophic_loss_of_feb_15_2026/
# TLS certificates (contain private keys)
certs/
services/evidence/models/
services/evidence/__pycache__/
