# =============================================================================
# NVR Project .gitignore
# =============================================================================
.gitignore 

# -----------------------------------------------------------------------------
# Config files (contain credentials) - track only .example and code files
# -----------------------------------------------------------------------------
config/


# -----------------------------------------------------------------------------
# Documentation - track only specific files
# Use docs/* (not docs/) so !exceptions below can re-include subtrees;
# git refuses to re-include children of a fully-excluded parent dir.
# -----------------------------------------------------------------------------
docs/*
DOCS/

# -----------------------------------------------------------------------------
# Project-specific ignores
# -----------------------------------------------------------------------------
**/0_*

# -----------------------------------------------------------------------------
# Documentation tree — whitelist (after docs/ and **/0_* ignores above).
# Reorganized 2026-04-28: structured docs live under docs/0_*/ subtrees.
# -----------------------------------------------------------------------------
# Anchor files at docs/ root (CLAUDE.md hardcoded paths + Jekyll site)
!docs/index.html
!docs/_config.yml
!docs/README_handoff.md
!docs/README_project_history.md
!docs/nvr_engineering_architecture.html
# Structured top-level subtrees (categorized per Apr 2026 reorg)
!docs/0_ARCHITECTURE/
!docs/0_ARCHITECTURE/**
!docs/0_PROPOSALS/
!docs/0_PROPOSALS/**
!docs/0_GUIDES/
!docs/0_GUIDES/**
!docs/0_CAMERAS/
!docs/0_CAMERAS/**
!docs/0_REFERENCE/
!docs/0_REFERENCE/**
!docs/0_LICENSE/
!docs/0_LICENSE/**
!docs/0_DIAGRAMS/
!docs/0_DIAGRAMS/**
!docs/0_SESSIONS/
!docs/0_SESSIONS/**
!docs/0_HISTORY/
!docs/0_HISTORY/**
# 0_DEPRECATED stays untracked (clutter / dup / swap files)
# Canonical workflow dirs (lowercase by convention)
!docs/teachings/
!docs/teachings/**
!docs/plans/
!docs/plans/**
!docs/weekly_summaries/
!docs/weekly_summaries/**
# Pre-Jan-2026 archive (name unchanged per user directive)
!docs/archive/
!docs/archive/**
# Re-exclude editor/sync swap files (.filename.md.XXXXXX) anywhere under docs/
docs/**/.*.md.*

# Evidence collection volume — symlink at ~/0_MOBIUS.NVR/litigation
# points to /litigation (a separate disk on dellserver). Never commit
# this symlink, its target, or any of its contents.
/litigation
litigation/
persistent.json
persistent.json.backup_2
bootstrap.json
tree.md
neolink/target/

# Personal scripts (untracked — use _deploy.sh and _start.sh instead)
deploy.sh
start.sh

# Backup files left by canonical-rule propagation agents
*.bak
*.bak.before_*

# SSH keys for container-to-host restart (private keys, never commit)
.ssh/

# Restart log (written by start.sh when triggered from app)
restart_from_app.log

# Deprecated/unused scripts
eufy_bridge.sh
eufy_bridge.py
eufy_bridge_client_verbose.py
eufy_bridge_watchdog.py
ptz_pan_right.py
ptz_server.py
PTZ_Discovery.py
stop_nvr_standalone.sh
**/DAMS_flat_copy.sh

# Claude/chat files
claude_rules.md
CLAUDE.md
*claude*
chat.md
chat*.md

# -----------------------------------------------------------------------------
# Security - certificates and environment
# -----------------------------------------------------------------------------
*.pem
*.cert
*.rsa
.env
.env.*
secrets.env

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
venv/
env/
ENV/
*.egg-info/
*.egg

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-debug.log

# -----------------------------------------------------------------------------
# Build/Distribution
# -----------------------------------------------------------------------------
dist/
build/
develop-eggs/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# -----------------------------------------------------------------------------
# Archives and compressed files
# -----------------------------------------------------------------------------
*.tar.gz
*.tar.bz2
*.tar
*.zip
*.tgz
*.gz
*.bz2
*.tbz
*.dmg
*.xpi
*.gem
*.rar
*.7z

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
test_*
_test*
*_test*
TESTS/
TESTS
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# -----------------------------------------------------------------------------
# Logs and temp files
# -----------------------------------------------------------------------------
*.log
**/app.log.*
*temp*
!templates/

# -----------------------------------------------------------------------------
# Backups, archives, copies, drafts
# -----------------------------------------------------------------------------
*backup*
**/backup/
**/backups/
**/archive/
*archive*
# (docs/archive/ exception is declared in the Documentation tree section above)
ARCHIVE/
*~.bak
*.backup
*.bak~
*.bak
*copy*
!**/copy_installation_files.sh
*draft*

# -----------------------------------------------------------------------------
# Media files
# -----------------------------------------------------------------------------
*.jpg

# -----------------------------------------------------------------------------
# Text files (track only requirements.txt)
# -----------------------------------------------------------------------------
*.txt
!requirements.txt

# -----------------------------------------------------------------------------
# HLS streaming segments
# -----------------------------------------------------------------------------
**/streams/
*stream/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
.git

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# VPN related
# -----------------------------------------------------------------------------
*vpn*


**/retrieved_files_post_catastrophic_loss_of_feb_15_2026/
# TLS certificates (contain private keys)
certs/
