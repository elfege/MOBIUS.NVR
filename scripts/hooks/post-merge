#!/bin/bash
# ─────────────────────────────────────────────────────────────────────
# post-merge hook: auto-push to public repo when main is updated
#
# Triggers after any `git merge` completes. If we're on main, pushes
# to the `public` remote (MOBIUS.NVR, semi-open-source).
#
# This ensures the public GitHub repo stays in sync with the dev repo's
# main branch without manual intervention.
#
# The push runs in the background (&) so it doesn't block the merge.
#
# SELF-PRESERVATION: This hook auto-copies itself to scripts/hooks/
# so it survives re-clones. The tracked copy is the canonical source.
# To install after a fresh clone: scripts/hooks/install-hooks.sh
# ─────────────────────────────────────────────────────────────────────

HOOK_DIR="$(git rev-parse --show-toplevel)/.git/hooks"
SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts/hooks"
HOOK_NAME="post-merge"

# ── Self-preservation: copy to tracked location if changed ────────
if [ -d "$SCRIPT_DIR" ]; then
    if ! cmp -s "$HOOK_DIR/$HOOK_NAME" "$SCRIPT_DIR/$HOOK_NAME" 2>/dev/null; then
        cp "$HOOK_DIR/$HOOK_NAME" "$SCRIPT_DIR/$HOOK_NAME"
        chmod +x "$SCRIPT_DIR/$HOOK_NAME"
        echo "[post-merge] Hook updated in scripts/hooks/ (will be tracked on next commit)."
    fi
fi

# ── Main logic: version-tag + push to public when on main ────────
branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel)"
    # Version-bump ./.tag and create v<version> annotated tag at HEAD.
    if [ -x "$REPO_ROOT/scripts/_auto_version.sh" ]; then
        "$REPO_ROOT/scripts/_auto_version.sh" || true
    fi
    new_tag="$(git tag --points-at HEAD 'v*.*.*' | sort -V | tail -1)"

    echo "[post-merge] On main — pushing to origin (private, background); publishing to public via publish_public_mirror.sh (foreground)..."
    # ── origin (private) push: backgrounded, no filtering needed ──
    (
        git push origin main
        [ -n "$new_tag" ] && git push origin "$new_tag"
    ) &>/dev/null &

    # ── public (cleansed) push: foreground so leak-gate aborts surface immediately ──
    # The raw `git push public main` of pre-2026-05-29 leaked private docs (plans,
    # teachings, archived handoffs). publish_public_mirror.sh runs filter-repo on
    # a /tmp build clone, leak-gates the result, and FF-pushes the cleansed view.
    if [ -x "$REPO_ROOT/scripts/publish_public_mirror.sh" ]; then
        "$REPO_ROOT/scripts/publish_public_mirror.sh" main \
            || echo "[post-merge] ⚠ publish_public_mirror.sh failed — public mirror NOT updated (see output above)" >&2
    else
        echo "[post-merge] ⚠ scripts/publish_public_mirror.sh missing — skipping public push" >&2
    fi
    echo "[post-merge] Done."
fi
