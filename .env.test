# =============================================================================
# MOBIUS.NVR — TEST environment overrides
# =============================================================================
# Loaded by:
#   docker compose -p nvr_test --env-file .env.test up -d
#
# All values are tuned for an isolated test run. They MUST be a strict
# superset of .env.example keys (the test-env conformity test guards this).
#
# Ports are offset by +10000 from .env.example so the test stack can run
# next to a live prod stack on the same host with no collision.
# =============================================================================

# --- Credential source ------------------------------------------------------
# Tests use a stubbed env-based config — no AWS, no real camera creds.
ENV_BASED_CONFIG=true

# --- Storage paths (all ephemeral under ./tmp_test/) ------------------------
# These directories are auto-created by the test fixtures and wiped between
# runs. Nothing here persists across `docker compose down -v`.
NVR_RECORDING_PATH=./tmp_test/recordings/recent
NVR_STORAGE_PATH=./tmp_test/recordings/archive
NVR_ALTERNATE_RECORDING_STORAGE=./tmp_test/recordings/alternate
NVR_POSTGRES_DATA=./tmp_test/postgres
NVR_LITIGATION_PATH=./tmp_test/evidence
NVR_SSH_CONFIG_ENTRIES_PATH=./tmp_test/ssh_config_entries

# --- Network ----------------------------------------------------------------
# Project name "nvr_test" (passed via -p) creates network "nvr_test_nvr-net"
# automatically. The names below shouldn't collide with prod.
NVR_NETWORK_NAME=nvr_test_nvr-net
NVR_ANAMNESIS_NETWORK=nvr_test_anamnesis-net
# All ports +10000 from .env.example defaults
NVR_EDGE_HTTP_PORT=18081
NVR_EDGE_HTTPS_PORT=18444
NVR_ADMIN_PORT=19100
NVR_LOCAL_HOST_IP=127.0.0.1
NVR_HOST_IP=127.0.0.1

# --- Service ports (all +10000 to coexist with prod on same host) -----------
NVR_FLASK_PORT=15000
NVR_POSTGRES_PORT=15432
NVR_POSTGREST_PORT=13001
NVR_MEDIAMTX_HLS_PORT=18888
NVR_MEDIAMTX_WHEP_PORT=18889
NVR_MEDIAMTX_WEBRTC_PORT=18189
NVR_GO2RTC_API_PORT=11984
NVR_GO2RTC_RTSP_PORT=18555
NVR_GO2RTC_WEBRTC_PORT=18557
NVR_NEOLINK_RTSP_PORT=18554
# Eufy P2P stays on prod ports because NVR_USE_EUFY_BRIDGE=0 means the
# bridge process doesn't actually bind anything in test mode.
NVR_EUFY_P2P_PORT_A=32100
NVR_EUFY_P2P_PORT_B=32108

# --- Flask ------------------------------------------------------------------
FLASK_ENV=testing
FLASK_DEBUG=0
NVR_LOG_LEVEL=WARNING
NVR_API_TOKEN=

# --- Vendor-specific features all OFF in test mode --------------------------
# Tests that need a feature ON will set it per-case via docker compose env
# overrides; the default base is a minimal stack with nothing optional.
NVR_USE_PROTECT=0
NVR_PROTECT_HOST=
NVR_PROTECT_PORT=7447
NVR_USE_EUFY_BRIDGE=0
NVR_USE_EUFY_BRIDGE_WATCHDOG=0
NVR_HUBITAT_HUB_IP=
NVR_HUBITAT_HUB_IP_4=

# --- Stream watchdog disabled in test mode (deterministic startup) ----------
NVR_STREAM_WATCHDOG_ENABLED=0
NVR_STREAM_WATCHDOG_INTERVAL_SEC=300
NVR_STREAM_WATCHDOG_RESTART_LIMIT=3

# --- HLS tuning (same as example) -------------------------------------------
NVR_HLS_SEGMENT_TIME=4
NVR_HLS_MAX_SEGMENTS=6
