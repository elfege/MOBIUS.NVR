        },
        "onvif": {
          "codec": "pcmu",
          "sample_rate": 8000,
          "backchannel_url": null,
          "go2rtc_stream": null
        },
        "baichuan": {
          "enabled": false
        }
      },
      "station": "T8010PDCD233B7F6",
