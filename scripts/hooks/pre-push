#!/usr/bin/env bash
# ----------------------------------------------------------------------------
# pre-push-block-private-paths.sh
#
# Pre-push git hook that refuses any push (to any remote) which would
# introduce or re-introduce operator-private paths into git history.
# Created 2026-05-13 after a post-merge auto-push to the public repo
# leaked docs/README_handoff.md + docs/README_project_history.md.
#
# Why pre-push and not pre-commit:
#   Pre-commit can be bypassed with --no-verify and doesn't see the
#   full set of commits about to leave the machine. Pre-push runs on
#   every push and inspects the commit RANGE being pushed.
#
# Install:
#   ln -sf ../../scripts/hooks/pre-push-block-private-paths.sh \
#         .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# (scripts/hooks/install-hooks.sh wires this up automatically.)
# ----------------------------------------------------------------------------
set -euo pipefail

PRIVATE_PATHS=(
    "docs/README_handoff.md"
    "docs/README_project_history.md"
    "docs/history/handoffs"
)
# Entries may be an exact file OR a directory prefix (e.g. the archived-handoff
# tree under docs/history/handoffs/<branch>/). The matcher below treats an
# entry as a hit when a tracked path equals it OR is nested under it. Added
# docs/history/handoffs 2026-05-25 after an archived handoff leaked to public.

# git pipes lines like:  <local-ref> <local-sha> <remote-ref> <remote-sha>
# We need to walk every commit in [remote-sha..local-sha] and check
# whether any of the PRIVATE_PATHS appear in its tree.

violations=0
while read -r local_ref local_sha remote_ref remote_sha; do
    [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue  # deleting branch

    # If the remote ref doesn't exist yet (new branch), check every reachable commit.
    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        range="$local_sha"
    else
        range="${remote_sha}..${local_sha}"
    fi

    for path in "${PRIVATE_PATHS[@]}"; do
        # Any commit in the pushed range that has this path?
        if git rev-list "$range" 2>/dev/null | while read -r sha; do
            if git ls-tree --name-only -r "$sha" 2>/dev/null | awk -v p="$path" '$0==p || index($0, p"/")==1 {f=1} END{exit !f}'; then
                echo "$sha"
                break
            fi
        done | grep -q .; then
            echo "❌ REFUSING PUSH: '$path' present in commit range $range (-> $remote_ref)" >&2
            violations=$((violations + 1))
        fi
    done
done

if [[ $violations -gt 0 ]]; then
    cat >&2 <<EOF

This hook refuses to push commits containing paths flagged as
operator-private. The flagged paths are:
$(printf "  - %s\n" "${PRIVATE_PATHS[@]}")

If you NEED to introduce one of these paths into history, edit
scripts/hooks/pre-push-block-private-paths.sh and remove it from the
PRIVATE_PATHS array — but think hard first. The original leak (2026-05-13)
exposed months of operator notes including LAN topology, camera names,
and internal design discussion to the public repo.

To bypass this hook for an emergency (NOT recommended):
  git push --no-verify ...

EOF
    exit 1
fi

exit 0
