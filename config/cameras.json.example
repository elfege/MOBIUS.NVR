  "last_updated": "EXAMPLE_FILE",
  "total_devices": 19,
  "__notes": {
    "notes_on_all_params": "see: ./config/cameras_json_notes.json"
  },
  "webrtc_global_settings": {
    "__notes": {
      "enable_dtls": "Enable DTLS-SRTP encryption for WebRTC. Required for iOS Safari which refuses unencrypted WebRTC. When enabled, iOS can use WebRTC (~200ms latency) instead of falling back to HLS (~2-4s latency). Adds ~10-20ms CPU overhead per frame for encryption, plus ~100-200ms one-time handshake. Recommended: true for production use with iOS users.",
      "ice_servers": "Optional STUN/TURN servers for NAT traversal. Empty array for LAN-only use. Add STUN server for external access: [{\"url\": \"stun:stun.l.google.com:19302\"}]"
    },
    "enable_dtls": true,
    "ice_servers": []
  },
  "ui_health_global_settings": {
    "__notes": {
      "UI_HEALTH_ENABLED": "Master switch: enables/disables entire UI health monitoring system. When false, no frame checks occur.",
      "UI_HEALTH_BLANK_AVG": "Luminance threshold (0-255 scale). Frame flagged blank if avg brightness < this value. Detects black/very dark screens. Uses ITU-R BT.601: Y = 0.299\u00d7R + 0.587\u00d7G + 0.114\u00d7B",
      "UI_HEALTH_BLANK_STD": "Standard deviation threshold for pixel brightness uniformity. Frames must have BOTH avg < BLANK_AVG AND std < BLANK_STD to trigger blank detection. Filters out grainy darkness and startup loading screens.",
      "UI_HEALTH_SAMPLE_INTERVAL_MS": "Milliseconds between frame samples. Lower = faster detection but higher CPU. Time to detect black screen = CONSECUTIVE_BLANK_NEEDED \u00d7 this value.",
      "UI_HEALTH_STALE_AFTER_MS": "Milliseconds of no frame signature change before marking stream stale. Detects frozen frames (same image for N milliseconds). Independent of black screen check.",
      "UI_HEALTH_CONSECUTIVE_BLANK_NEEDED": "How many consecutive black samples required to trigger restart. Prevents false positives from brief stalls. Formula: detection_time = this \u00d7 SAMPLE_INTERVAL_MS",
      "UI_HEALTH_COOLDOWN_MS": "Milliseconds to wait after health alert before allowing next restart attempt. Prevents restart loops if stream keeps failing immediately.",
      "UI_HEALTH_WARMUP_MS": "Milliseconds to wait after attaching monitor before checking health. Allows stream initial buffering/startup without false triggers. Monitoring suppressed for this duration.",
      "UI_HEALTH_MAX_ATTEMPTS": "Maximum restart attempts before giving up. Set to 0 for infinite attempts (not recommended - may cause endless restart loops for permanently failed cameras)."
    },
    "UI_HEALTH_ENABLED": true,
    "UI_HEALTH_BLANK_AVG": 5,
    "UI_HEALTH_BLANK_STD": 3,
    "UI_HEALTH_SAMPLE_INTERVAL_MS": 2000,
    "UI_HEALTH_STALE_AFTER_MS": 10000,
    "UI_HEALTH_CONSECUTIVE_BLANK_NEEDED": 3,
    "UI_HEALTH_COOLDOWN_MS": 30000,
    "UI_HEALTH_WARMUP_MS": 15000,
    "UI_HEALTH_MAX_ATTEMPTS": 50000
  }
}
