# =============================================================================
# NVR Secrets Configuration
# =============================================================================
# Copy this file to secrets.env and fill in your values.
# Set ENV_BASED_CONFIG=true in .env to use this file instead of AWS.
#
# Camera credentials (usernames/passwords) can also be added via the web UI
# after first startup — they are stored encrypted in the database.
# The env vars below are only needed for:
#   - First-run migration (env vars -> database)
#   - Third-party containers (go2rtc, MediaMTX) that read creds from config files
# =============================================================================

# --- REQUIRED ---

# PostgreSQL database password (auto-generated on first run if empty)
POSTGRES_PASSWORD=

# Flask secret key for session encryption (auto-generated if empty)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
NVR_SECRET_KEY=

# --- CAMERA CREDENTIALS (optional — can be added via web UI instead) ---

# Reolink cameras (brand-level, shared by all Reolink cameras)
# NVR_REOLINK_USERNAME=
# NVR_REOLINK_PASSWORD=
# NVR_REOLINK_API_USER=
# NVR_REOLINK_API_PASSWORD=

# Amcrest cameras
# NVR_AMCREST_LOBBY_USERNAME=
# NVR_AMCREST_LOBBY_PASSWORD=

# SV3C cameras
# NVR_SV3C_USERNAME=
# NVR_SV3C_PASSWORD=

# UniFi Protect console (for API access, not RTSP)
# NVR_PROTECT_USERNAME=
# NVR_PROTECT_SERVER_PASSWORD=

# UniFi Controller (for POE power control)
# NVR_UNIFI_CONTROLLER_HOST=
# NVR_UNIFI_CONTROLLER_USERNAME=
# NVR_UNIFI_CONTROLLER_PASSWORD=

# Eufy bridge (for PTZ control)
# NVR_EUFY_BRIDGE_USERNAME=
# NVR_EUFY_BRIDGE_PASSWORD=

# Eufy per-camera credentials (one pair per camera serial)
# NVR_EUFY_CAMERA_SERIALNUMBER1_USERNAME=
# NVR_EUFY_CAMERA_SERIALNUMBER1_PASSWORD=

# --- OPTIONAL SERVICE TOKENS ---

# Hubitat smart home integration (power control for cameras)
# NVR_HUBITAT_API_TOKEN=
# NVR_HUBITAT_API_APP_NUMBER=

# External API bearer token (for TILES or other integrations)
# When empty, external API falls back to LAN-only IP check
# NVR_API_TOKEN=
